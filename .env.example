# imagik object storage configuration
# ----------------------------------
# mode: "s3" (AWS S3 / Cloudflare R2 compatible) or "signed_url"
IMAGIK_STORAGE_MODE=s3

# required for s3 mode
IMAGIK_STORAGE_BUCKET=your-bucket-name
IMAGIK_STORAGE_REGION=auto
# for Cloudflare R2/custom endpoints, set endpoint explicitly
# example: https://<accountid>.r2.cloudflarestorage.com
IMAGIK_STORAGE_ENDPOINT=
IMAGIK_STORAGE_FORCE_PATH_STYLE=true

# optional: prepend this prefix to every object key requested from /image/{object_key}
# IMAGIK_STORAGE_KEY_PREFIX=images

# credentials (recommended via environment/secret manager; do not hardcode)
# if unset, AWS SDK default credential chain is used.
IMAGIK_STORAGE_ACCESS_KEY_ID=
IMAGIK_STORAGE_SECRET_ACCESS_KEY=
IMAGIK_STORAGE_SESSION_TOKEN=

# signed-url mode
# use {key} placeholder for dynamic key mapping from request path.
# if {key} is omitted, key is appended to this base URL.
# example:
# IMAGIK_STORAGE_SIGNED_URL_TEMPLATE=https://cdn.example.com/private/{key}?token=...
IMAGIK_STORAGE_SIGNED_URL_TEMPLATE=

# storage request timeouts and retries
IMAGIK_STORAGE_CONNECT_TIMEOUT_MS=1500
IMAGIK_STORAGE_TIMEOUT_MS=5000
IMAGIK_STORAGE_MAX_RETRIES=3
IMAGIK_STORAGE_RETRY_BACKOFF_MS=150
IMAGIK_STORAGE_MAX_OBJECT_BYTES=67108864

# optional local disk cache for object storage fetches
IMAGIK_STORAGE_CACHE_DIR=
IMAGIK_STORAGE_CACHE_TTL_SECS=600
IMAGIK_STORAGE_CACHE_MAX_BYTES=536870912

# external cache (Redis / DragonflyDB)
# ------------------------------------
# if unset, external cache is disabled (in-process hot cache can still be enabled)
IMAGIK_CACHE_URL=
IMAGIK_CACHE_PREFIX=imagik:v1

# ttl policy
# final transform cache TTL should be longer than source cache TTL
IMAGIK_CACHE_RESULT_TTL_SECS=3600
IMAGIK_CACHE_SOURCE_TTL_SECS=300
IMAGIK_CACHE_VERSION_TTL_SECS=30

# max cacheable payload sizes (bytes)
IMAGIK_CACHE_RESULT_MAX_STORE_BYTES=8388608
IMAGIK_CACHE_SOURCE_MAX_STORE_BYTES=16777216

# stampede protection (distributed lock + wait window)
IMAGIK_CACHE_LOCK_TTL_MS=60000
IMAGIK_CACHE_LOCK_WAIT_MS=20000
IMAGIK_CACHE_LOCK_POLL_MS=50
IMAGIK_CACHE_LOCK_HEARTBEAT_MS=5000
IMAGIK_CACHE_UNKNOWN_RESULT_TTL_SECS=5

# optional adaptive TTL based on access frequency
IMAGIK_CACHE_ADAPTIVE_TTL=false
IMAGIK_CACHE_FREQ_WINDOW_SECS=300
IMAGIK_CACHE_HOT_THRESHOLD=16
IMAGIK_CACHE_HOT_TTL_MULTIPLIER=3

# redis/dragonfly metrics sampling interval
IMAGIK_CACHE_INFO_SAMPLE_INTERVAL_MS=5000

# optional in-process hot result cache (final encoded output only)
# strict caps prevent RAM growth under load
IMAGIK_HOT_CACHE_ENABLED=true
IMAGIK_HOT_CACHE_MAX_BYTES=67108864
IMAGIK_HOT_CACHE_MAX_ENTRY_BYTES=2097152
IMAGIK_HOT_CACHE_MAX_ITEMS=512

# runtime knobs (optional)
IMAGIK_MAX_BLOCKING_THREADS=
IMAGIK_BLOCKING_KEEP_ALIVE_MS=3000
IMAGIK_TRANSFORM_CONCURRENCY=
IMAGIK_RSS_SAMPLE_INTERVAL_MS=1000
IMAGIK_MAX_DECODE_PIXELS=128000000
IMAGIK_MAX_DECODE_DIMENSION=16384
IMAGIK_MAX_DECODE_ALLOC_BYTES=536870912
